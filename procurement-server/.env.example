# ============================================================
# 采购系统后端环境变量配置模板
# 使用方式：cp .env.example .env，然后填写真实值
# 生产部署时通过 export 或 systemd EnvironmentFile 注入
# ============================================================

# ============================================================
# 安全 / JWT（必填）
# ============================================================
# 生产环境必须设置，至少 32 位随机字符串，不可使用默认值
JWT_SECRET=your-super-secure-jwt-secret-min-32-chars


# ============================================================
# 微信小程序（必填）
# ============================================================
WX_APP_ID=your_wx_app_id
WX_APP_SECRET=your_wx_app_secret

# 低库存预警订阅消息模板 ID（可选，不填则不推送）
WX_STOCK_WARNING_TEMPLATE_ID=

# 备份失败告警订阅消息模板 ID（可选，不填则不推送）
WX_BACKUP_ALERT_TEMPLATE_ID=


# ============================================================
# 数据库 MySQL（必填）
# ============================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
# 生产环境必须填写强密码
DB_PASSWORD=your_mysql_password


# ============================================================
# 缓存 Redis
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# 如果 Redis 未设置密码则留空
REDIS_PASSWORD=


# ============================================================
# 文件存储
# ============================================================
# 本地图片存储目录（相对路径或绝对路径）
FILE_LOCAL_DIR=/opt/procurement/data/image

# 腾讯云 COS 对象存储（可选，不填则使用本地存储）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=


# ============================================================
# 数据备份
# ============================================================
# 备份文件存储目录
BACKUP_DIR=/opt/procurement/backup

# 自动备份 Cron 表达式（默认每天凌晨 3 点）
BACKUP_AUTO_CRON=0 0 3 * * ?


# ============================================================
# 跨域 CORS
# ============================================================
# 生产环境精确配置允许的来源，多个用逗号分隔
CORS_ALLOWED_ORIGINS=https://servicewechat.com
